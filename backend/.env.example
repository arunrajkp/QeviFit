PORT=5000
NODE_ENV=development

# Authentication
JWT_SECRET=generate_a_very_secure_random_string_here_like_dj92jd9834
JWT_EXPIRES_IN=7d

# Firebase Admin SDK Credentials
# Go to Firebase Console -> Project Settings -> Service Accounts
# Click "Generate new private key", open the JSON file and paste these values:
FIREBASE_PROJECT_ID="your_project_id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com"
# WARNING: When pasting FIREBASE_PRIVATE_KEY below, ensure ALL literal \n characters are maintained! Do not strip them out.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nVery\nLong\nKey\nEnds\nHere\n-----END PRIVATE KEY-----\n"

# Frontend Integration
FRONTEND_URL=http://localhost:3000
